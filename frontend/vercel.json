{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://platform-api-production-3d04.up.railway.app/:path*"
    },
    {
      "source": "/call/:path*",
      "destination": "https://orchestrator-production-dde7.up.railway.app/call/:path*"
    },
    {
      "source": "/sessions/:path*",
      "destination": "https://orchestrator-production-dde7.up.railway.app/sessions/:path*"
    },
    {
      "source": "/sessions",
      "destination": "https://orchestrator-production-dde7.up.railway.app/sessions"
    },
    {
      "source": "/health",
      "destination": "https://orchestrator-production-dde7.up.railway.app/health"
    },
    {
      "source": "/voices",
      "destination": "https://orchestrator-production-dde7.up.railway.app/voices"
    },
    {
      "source": "/recordings/:path*",
      "destination": "https://orchestrator-production-dde7.up.railway.app/recordings/:path*"
    }
  ]
}
