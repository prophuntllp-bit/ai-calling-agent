# ── Telephony ──────────────────────────────────────────────────
TELEPHONY_PROVIDER=enablex
ENABLEX_APP_ID=your_enablex_app_id
ENABLEX_APP_KEY=your_enablex_app_key
ENABLEX_FROM_NUMBER=+91XXXXXXXXXX
ENABLEX_VOICE_BASE_URL=https://api.enablex.io/voice/v1

# ── Public host (set to Railway orchestrator public URL) ────────
PUBLIC_HOST=your-orchestrator.up.railway.app

# ── Sarvam AI ──────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key
SARVAM_API_URL=https://api.sarvam.ai
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_PACE=1.0
SARVAM_TTS_SAMPLE_RATE=24000

# ── STT ────────────────────────────────────────────────────────
STT_PROVIDER=local
WHISPER_MODEL=tiny

# ── TTS ────────────────────────────────────────────────────────
TTS_PROVIDER=sarvam

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/voiceai

# ── Redis (Upstash) ────────────────────────────────────────────
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ── Internal service URLs (Railway private network) ────────────
STT_URL=http://stt.railway.internal:8002
TTS_URL=http://tts.railway.internal:8003
VAD_URL=http://vad.railway.internal:8001
CRM_ADAPTER_URL=http://crm-adapter.railway.internal:8010
KNOWLEDGE_SERVICE_URL=http://knowledge-service.railway.internal:8011
PLATFORM_API_URL=http://platform-api.railway.internal:8013
CAMPAIGN_SERVICE_URL=http://campaign-service.railway.internal:8012
ORCHESTRATOR_URL=http://orchestrator.railway.internal:8000

# ── Security ───────────────────────────────────────────────────
ORCHESTRATOR_INTERNAL_TOKEN=change-me-to-random-secret
JWT_SECRET=change-me-to-random-secret

# ── Embedding (Modal.run) ──────────────────────────────────────
EMBEDDING_PROVIDER=http
EMBEDDING_API_URL=https://prophuntllp--voice-ai-platform-embedding-api-fastapi-app.modal.run/embed

# ── App ────────────────────────────────────────────────────────
CORS_ORIGINS=https://prophunt-dashboard.vercel.app
MAX_CONCURRENT_CALLS=10
PORT=8000
